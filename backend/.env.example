# DataAgent Backend Configuration

# Your Gemini API Key from aistudio.google.com (Required for backend LLM features)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# Deployed frontend URL(s) to restrict CORS access (optional, defaults to allow localhost in development)
# For production, set this to your Vercel deployment URL (e.g. https://data-agent.vercel.app)
# You can specify multiple origins separated by commas.
FRONTEND_URL=https://data-agent-frontend.vercel.app
