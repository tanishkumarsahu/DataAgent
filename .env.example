# DataAgent Root Configuration Example

# ====================
# BACKEND SETTINGS
# ====================
# Gemini API Key from aistudio.google.com (Required for chat and insights)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# Deployed frontend URL(s) to restrict CORS access (optional, defaults to allow localhost)
FRONTEND_URL=https://data-agent-frontend.vercel.app


# ====================
# FRONTEND SETTINGS
# ====================
# Deployed backend API base URL (e.g. Render app URL)
# For production, set this to your deployed Render URL (without trailing slash, e.g. https://data-agent-backend.onrender.com)
# Leave blank or omit in local development to use the Vite dev server proxy (/api/*)
VITE_API_BASE_URL=https://data-agent-backend.onrender.com
