# DataAgent Frontend Configuration

# Deployed backend API base URL (e.g. Render app URL)
# For production, set this to your deployed Render URL (without trailing slash, e.g. https://data-agent-backend.onrender.com)
# Leave blank or omit in local development to use the Vite dev server proxy (/api/*)
VITE_API_BASE_URL=https://data-agent-backend.onrender.com
